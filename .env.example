APP_NAME="Filosofi Photobooth"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=filosofi_photobooth
DB_USERNAME=root
DB_PASSWORD=
# Untuk SQLite (tanpa server MySQL), ganti menjadi:
# DB_CONNECTION=sqlite

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log
MAIL_FROM_ADDRESS="halo@filosofiphotobooth.id"
MAIL_FROM_NAME="${APP_NAME}"

# Akun admin pertama (dipakai oleh: php artisan db:seed)
# Setelah login pertama, SEGERA ganti password lewat menu "Ganti Password".
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Notifikasi WhatsApp
# WA_ADMIN: nomor WA pemilik, format 62xxx (contoh: 6281234567890)
# FONNTE_TOKEN: token dari fonnte.com untuk notif otomatis (opsional)
WA_ADMIN=
FONNTE_TOKEN=
